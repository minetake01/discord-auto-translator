DISCORD_TOKEN=your-discord-bot-token
# Cloudflare: one API token per deployment environment (scoped by the operator).
CLOUDFLARE_ACCOUNT_ID=your-cloudflare-account-id
CLOUDFLARE_API_TOKEN=your-cloudflare-api-token
# AI Gateway ID; use a different value per environment when needed.
CLOUDFLARE_AI_GATEWAY_ID=your-cloudflare-ai-gateway-id
DB_PATH=./translator.db
HTTP_ADDR=:8080
PUBLIC_BASE_URL=https://your-public-domain.example
# Per-guild @cf/google/gemma-4-26b-a4b-it token limit per minute (default: 100000).
TRANSLATION_RATE_LIMIT_TOKENS_PER_MIN=100000
AVATAR_RATE_LIMIT_REQUESTS_PER_MIN=120
